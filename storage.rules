rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || (
            firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function ownsBusiness(businessId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/businesses/$(businessId))
        && firestore.get(/databases/(default)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid;
    }

    // Covers team photos  (businesses/{id}/team-photos/),
    // gallery photos      (businesses/{id}/photos/),
    // and marketplace     (businesses/{id}/marketplace/).
    match /businesses/{businessId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || ownsBusiness(businessId);
    }

    // Review photos — uploaded by the reviewing visitor only.
    match /reviews/{businessId}/{authorUid}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || (signedIn() && request.auth.uid == authorUid);
    }

    function isGroupMember(groupId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // Group cover photos and post photos — uploaded by group members only.
    match /groups/{groupId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isGroupMember(groupId);
    }
  }
}
