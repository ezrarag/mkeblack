rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function ownsBusiness() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isEmailMatchClaim() {
      return signedIn()
        && resource.data.ownerUid == null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.claimInviteStatus == "claimed"
        && resource.data.emailLower == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "ownerUid",
          "claimInviteStatus"
        ]);
    }

    function ownsBusinessById(businessId) {
      return signedIn()
        && exists(/databases/$(database)/documents/businesses/$(businessId))
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid;
    }

    function isSolidarityBusiness(businessId) {
      return exists(/databases/$(database)/documents/businesses/$(businessId))
        && get(/databases/$(database)/documents/businesses/$(businessId)).data.solidarityMember == true;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validContactSubmitterUid() {
      return !("submitterUid" in request.resource.data)
        || request.resource.data.submitterUid == null
        || (signedIn() && request.resource.data.submitterUid == request.auth.uid);
    }

    function validContactSubmissionStatus() {
      return !("status" in request.resource.data)
        || request.resource.data.status == null
        || request.resource.data.status == "pending";
    }

    function canAttachContactSubmitter() {
      return signedIn()
        && resource.data.reason == "submit_business"
        && resource.data.status == "pending"
        && (!("submitterUid" in resource.data) || resource.data.submitterUid == null)
        && request.resource.data.submitterUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "submitterUid",
          "submitterDisplayName",
          "submitterPhotoUrl",
          "ownerName",
          "ownerEmail"
        ]);
    }

    // ── Businesses ──────────────────────────────────────────────────────────
    match /businesses/{businessId} {
      allow read: if resource.data.active == true || isAdmin() || ownsBusiness();
      allow create: if isAdmin();
      allow update: if isAdmin() || ownsBusiness() || isEmailMatchClaim();
      allow delete: if isAdmin()
                    || (signedIn() && resource.data.creatorUid == request.auth.uid);
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid) || isAdmin();
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Homepage Modules ─────────────────────────────────────────────────────
    match /homepage_modules/{moduleId} {
      allow read: if resource.data.visible == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Member Discounts ─────────────────────────────────────────────────────
    match /member_discounts/{discountId} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Public site configuration ────────────────────────────────────────────
    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Newsletter subscribers ───────────────────────────────────────────────
    match /newsletter_subscribers/{subscriberId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // ── Contact submissions ─────────────────────────────────────────────────
    match /contactSubmissions/{submissionId} {
      allow create: if validContactSubmitterUid() && validContactSubmissionStatus();
      allow read, delete: if isAdmin();
      allow update: if isAdmin() || canAttachContactSubmitter();
    }

    // ── Articles ─────────────────────────────────────────────────────────────
    match /articles/{articleId} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ── Members (Solidarity Circle) ──────────────────────────────────────────
    match /members/{memberId} {
      allow read: if isSelf(memberId) || isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Benefit Types ────────────────────────────────────────────────────────
    match /benefit_types/{benefitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Business Claim Invites (admin-sent) ──────────────────────────────────
    match /business_claim_invites/{businessId} {
      allow read: if true;
      allow write: if isAdmin() || signedIn();
    }

    // ── Pending Claims (self-service, awaiting admin verification) ───────────
    match /pending_claims/{claimId} {
      // Any signed-in user can create a self-claim
      allow create: if signedIn();
      // Only admin can read/update/delete (for verification workflow)
      allow read, update, delete: if isAdmin();
    }

    // ── Public business issue reports ───────────────────────────────────────
    match /business_reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Admin sync sessions (hours scrub tool) ───────────────────────────────
    match /admin_sync_sessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    // ── Milwaukee neighborhoods (GIS cache) ──────────────────────────────────
    match /milwaukee_neighborhoods/{neighborhoodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Business tags ────────────────────────────────────────────────────────
    match /business_tags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Business categories ──────────────────────────────────────────────────
    match /business_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Events ───────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if resource.data.status == "published"
                  || isAdmin()
                  || ownsBusinessById(resource.data.businessId);
      allow create: if isAdmin()
                    || (
                      ownsBusinessById(request.resource.data.businessId)
                      && isSolidarityBusiness(request.resource.data.businessId)
                      && request.resource.data.businessSolidarity == true
                    );
      allow update: if isAdmin()
                    || (
                      ownsBusinessById(resource.data.businessId)
                      && isSolidarityBusiness(resource.data.businessId)
                      && request.resource.data.businessId == resource.data.businessId
                      && request.resource.data.businessSolidarity == true
                    );
      allow delete: if isAdmin()
                    || ownsBusinessById(resource.data.businessId);
    }

    // ── Professionals directory ──────────────────────────────────────────────
    match /professionals/{professionalId} {
      allow read: if resource.data.active == true || isAdmin();
      allow create: if signedIn();
      allow update: if isAdmin() ||
        (signedIn() && request.auth.uid == resource.data.uid);
      allow delete: if isAdmin();
    }

    // ── Marketplace listings ─────────────────────────────────────────────────
    match /marketplace_listings/{listingId} {
      // Public reads only when available; admins and the owning business see all
      allow read: if resource.data.available == true
                  || isAdmin()
                  || ownsBusinessById(resource.data.businessId);
      // Only the owning business (Solidarity members) or admin can create/update
      allow create: if isAdmin()
                    || (
                      ownsBusinessById(request.resource.data.businessId)
                      && isSolidarityBusiness(request.resource.data.businessId)
                      && request.resource.data.businessSolidarity == true
                    );
      allow update: if isAdmin()
                    || (
                      ownsBusinessById(resource.data.businessId)
                      && isSolidarityBusiness(resource.data.businessId)
                      && request.resource.data.businessId == resource.data.businessId
                      && request.resource.data.businessSolidarity == true
                    );
      allow delete: if isAdmin()
                    || ownsBusinessById(resource.data.businessId);
    }

    // ── Visitor ↔ Business messaging ─────────────────────────────────────────
    // One thread per (visitor, business) pair, id = `${businessId}_${visitorUid}`.
    // Only the two participants and admin may read/write. Threads can only be
    // created against Solidarity Circle member businesses.
    function isThreadParticipant(threadData) {
      return signedIn() && (
        request.auth.uid == threadData.visitorUid ||
        ownsBusinessById(threadData.businessId)
      );
    }

    match /message_threads/{threadId} {
      allow read: if isAdmin() || isThreadParticipant(resource.data);
      allow create: if isAdmin()
                    || (
                      signedIn()
                      && request.resource.data.visitorUid == request.auth.uid
                      && request.resource.data.businessId is string
                      && isSolidarityBusiness(request.resource.data.businessId)
                      && threadId == request.resource.data.businessId + "_" + request.auth.uid
                    );
      // Participants may only update preview/unread fields — never reassign
      // the thread to a different visitor or business.
      allow update: if isAdmin()
                    || (
                      isThreadParticipant(resource.data)
                      && request.resource.data.visitorUid == resource.data.visitorUid
                      && request.resource.data.businessId == resource.data.businessId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        "lastMessage",
                        "lastMessageAt",
                        "lastSenderRole",
                        "visitorUnread",
                        "businessUnread"
                      ])
                    );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin()
                    || isThreadParticipant(get(/databases/$(database)/documents/message_threads/$(threadId)).data);
        allow create: if isAdmin()
                      || (
                        isThreadParticipant(get(/databases/$(database)/documents/message_threads/$(threadId)).data)
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 4000
                      );
        allow update, delete: if isAdmin();
      }
    }

    // ── Business reviews ──────────────────────────────────────────────────────
    // One review per (visitor, business) pair, id = `${businessId}_${authorUid}`
    // — an upsert pattern so resubmitting edits the existing review. Reviews
    // are public read (social proof). Authors may only edit their own content
    // fields; `status` (flagged/removed) is admin-controlled moderation.
    function validNewReview() {
      return request.resource.data.authorUid == request.auth.uid
        && request.resource.data.businessId is string
        && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId))
        && reviewId == request.resource.data.businessId + "_" + request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAdmin() || (signedIn() && validNewReview());
      // Authors may resubmit/edit their own content — never reassign
      // authorship or businessId, and never self-moderate `status`.
      allow update: if isAdmin()
                    || (
                      signedIn()
                      && resource.data.authorUid == request.auth.uid
                      && request.resource.data.authorUid == resource.data.authorUid
                      && request.resource.data.businessId == resource.data.businessId
                      && request.resource.data.status == resource.data.status
                      && request.resource.data.rating is int
                      && request.resource.data.rating >= 1
                      && request.resource.data.rating <= 5
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 2000
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        "rating",
                        "text",
                        "photos",
                        "relatedListingId",
                        "relatedListingName",
                        "relatedEventId",
                        "relatedEventName",
                        "updatedAt"
                      ])
                    );
      allow delete: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);
    }

    // ── Visitor-created community groups ──────────────────────────────────────
    // Facebook-style fan/community groups that any signed-in visitor can start,
    // optionally tied to a business. Membership lives in a `members` subcollection
    // keyed by uid (deterministic — one membership per person), and `posts` is a
    // feed subcollection. Groups + posts are publicly readable (discovery/social
    // proof); only members may post, and only the creator (owner) or admins may
    // manage membership/moderation.
    function isGroupMemberUid(groupId, uid) {
      return exists(/databases/$(database)/documents/groups/$(groupId)/members/$(uid));
    }

    function isGroupOwnerUid(groupId, uid) {
      let memberPath = /databases/$(database)/documents/groups/$(groupId)/members/$(uid);
      return exists(memberPath) && get(memberPath).data.role == "owner";
    }

    function validNewGroup() {
      return request.resource.data.creatorUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 1000
        && request.resource.data.status == "active";
    }

    match /groups/{groupId} {
      allow read: if resource.data.status == "active"
                  || isAdmin()
                  || (signedIn() && resource.data.creatorUid == request.auth.uid);
      allow create: if isAdmin() || (signedIn() && validNewGroup());
      // Owners may edit their group's profile fields — never reassign creatorUid,
      // touch timestamps, or self-moderate `status`.
      allow update: if isAdmin()
                    || (
                      signedIn()
                      && resource.data.creatorUid == request.auth.uid
                      && request.resource.data.creatorUid == resource.data.creatorUid
                      && request.resource.data.status == resource.data.status
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.name.size() <= 80
                      && request.resource.data.description is string
                      && request.resource.data.description.size() <= 1000
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        "name",
                        "description",
                        "businessId",
                        "businessName",
                        "coverPhotoUrl",
                        "updatedAt"
                      ])
                    );
      allow delete: if isAdmin();

      match /members/{uid} {
        allow read: if true;
        // A person can only seat themselves — as "owner" exactly when they're
        // the group's creator (the very first member), otherwise as "member".
        allow create: if isAdmin()
                      || (
                        signedIn()
                        && request.auth.uid == uid
                        && request.resource.data.displayName is string
                        && request.resource.data.role == (
                          get(/databases/$(database)/documents/groups/$(groupId)).data.creatorUid == uid
                            ? "owner"
                            : "member"
                        )
                      );
        // Role changes (e.g. promoting a co-owner) are admin-only.
        allow update: if isAdmin();
        allow delete: if isAdmin()
                      || (signedIn() && request.auth.uid == uid)
                      || (signedIn() && isGroupOwnerUid(groupId, request.auth.uid));
      }

      match /posts/{postId} {
        allow read: if true;
        allow create: if isAdmin()
                      || (
                        signedIn()
                        && isGroupMemberUid(groupId, request.auth.uid)
                        && request.resource.data.authorUid == request.auth.uid
                        && request.resource.data.status == "published"
                        && request.resource.data.text is string
                        && request.resource.data.text.size() <= 4000
                        && (request.resource.data.text.size() > 0 || request.resource.data.photos.size() > 0)
                      );
        // Authors may edit their own content; anyone signed in may toggle their
        // own like; owners/admins moderate `status`. Each lane only touches its
        // own fields — never reassigning authorship.
        allow update: if isAdmin()
                      || (
                        signedIn()
                        && resource.data.authorUid == request.auth.uid
                        && request.resource.data.authorUid == resource.data.authorUid
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.text is string
                        && request.resource.data.text.size() <= 4000
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["text", "photos", "updatedAt"])
                      )
                      || (
                        signedIn()
                        && isGroupOwnerUid(groupId, request.auth.uid)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
                      )
                      || (
                        signedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likeUids", "updatedAt"])
                        && request.resource.data.likeUids.toSet().difference(resource.data.likeUids.toSet())
                            .union(resource.data.likeUids.toSet().difference(request.resource.data.likeUids.toSet()))
                            == [request.auth.uid].toSet()
                      );
        allow delete: if isAdmin()
                      || (signedIn() && resource.data.authorUid == request.auth.uid)
                      || (signedIn() && isGroupOwnerUid(groupId, request.auth.uid));
      }
    }

    // ── Consumer favorites (subcollection under users) ───────────────────────
    match /users/{uid}/notifications/{notificationId} {
      allow read, update: if isSelf(uid);
      allow create: if signedIn();
      allow delete: if isSelf(uid) || isAdmin();
    }

    // ── Consumer favorites (subcollection under users) ───────────────────────
    match /users/{uid}/favorites/{businessId} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // ── Recent views (subcollection under users) ─────────────────────────────
    match /users/{uid}/recent_views/{businessId} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // ── Saved marketplace listings (subcollection under users) ───────────────
    match /users/{uid}/saved_marketplace/{listingId} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // ── Business reviews (subcollection under businesses) ────────────────────
    match /businesses/{businessId}/reviews/{reviewId} {
      allow read: if resource.data.visible == true || isAdmin();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // ── Business team (subcollection) ────────────────────────────────────────
    match /businesses/{businessId}/team/{memberId} {
      allow read: if resource.data.visible == true || isAdmin() || ownsBusinessById(businessId);
      allow write: if isAdmin() || ownsBusinessById(businessId);
    }

    // ── Google Workspace cache ────────────────────────────────────────────────
    match /gw_drive/{fileId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /gw_calendar/{eventId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /gw_gmail/{threadId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
